# ─── Core ───────────────────────────────────────────────────────────
APP_MODE=demo            # demo | production
GRID_ROWS=4
GRID_COLS=5

# ─── Shelf Region (pixel coords, 0-1 normalised) ─────────────────────
SHELF_X1=0.05
SHELF_Y1=0.10
SHELF_X2=0.95
SHELF_Y2=0.90

# ─── YOLO Model ──────────────────────────────────────────────────────
# Leave blank to use default yolov8n.pt
CUSTOM_MODEL_PATH=

# ─── Google Gemini API ────────────────────────────────────────────────
# Get free key at https://aistudio.google.com/
GEMINI_API_KEY=

# ─── Twilio WhatsApp ─────────────────────────────────────────────────
# Sign up at https://www.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=whatsapp:+14155238886
TWILIO_TO=whatsapp:+91XXXXXXXXXX

# ─── Scheduler ───────────────────────────────────────────────────────
DAILY_REPORT_HOUR=20
DAILY_REPORT_MINUTE=0
